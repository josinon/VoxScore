# URL do PostgreSQL (ex.: stack local em ../docker-compose.yml)
DATABASE_URL=postgresql://voxscore:voxscore@localhost:5432/voxscore

# Porta HTTP da API (opcional)
PORT=3000

# JWT (obrigatório para arrancar a API) — mínimo ~32 caracteres recomendado
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=15m

# Primeiro ADMIN (bootstrap quando não existe nenhum ADMIN na base)
BOOTSTRAP_ADMIN_EMAIL=admin@voxscore.local
BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator

# Apenas desenvolvimento/CI: emite POST /api/v1/auth/dev/token — NUNCA true em produção
AUTH_DEV_TOKEN_ENABLED=false

# Mock de OAuth Google (POST /api/v1/auth/oauth/mock) — NUNCA true em produção
AUTH_GOOGLE_MOCK_ENABLED=false

# OAuth Google (produção / staging real). Callback deve coincidir com a consola Google.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
# Após login, redirecionar o browser para esta origem com fragment #access_token=<JWT>
# OMITIR = resposta JSON { accessToken } no callback (útil para testes manuais).
# OAUTH_FRONTEND_REDIRECT_URL=http://localhost:5173/oauth/callback

# CORS: lista separada por vírgulas (omitir = refletir pedidos ou política permissiva em dev)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Migrações ao arrancar: omitir ou `true` = aplica migrações pendentes (bom para local).
# `false` = não aplicar (use em K8s com várias réplicas + Job de migrate).
TYPEORM_MIGRATIONS_RUN=true

# OpenAPI / Swagger em `/api/v1/docs` (defina `false` para desligar)
# SWAGGER_ENABLED=false

# SSL do cliente Postgres (ex.: produção em nuvem)
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
