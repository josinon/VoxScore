# URL absoluta da API (ex.: http://localhost:3000/api/v1).
# Se omitir, o cliente usa caminhos relativos /api/v1 (requer proxy no Vite — ver vite.config.ts).
# VITE_API_BASE_URL=http://localhost:3000/api/v1

# Origem do SPA para o redirect OAuth Google (deve coincidir com OAUTH_FRONTEND_REDIRECT_URL no backend).
# Ex.: http://localhost:5173 — a rota /oauth/callback recebe #access_token=...
# VITE_OAUTH_REDIRECT_ORIGIN=http://localhost:5173

# Expor formulário de login por mock OAuth em builds não-dev (ex.: Playwright com vite preview).
# VITE_SHOW_DEV_LOGIN=false

# WebSocket em tempo real (candidatos / ranking). Em `false` a SPA não abre WS (ex.: e2e sem backend).
# VITE_REALTIME_ENABLED=true
